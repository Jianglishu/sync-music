{
  "name": "sync-music",
  "version": "1.0.0",
  "description": "多设备音乐同步播放器 - Multi-device synchronized music player",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"sleep 3 && electron .\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "nat-upnp": "^1.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.syncmusic.app",
    "productName": "SyncMusic",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/renderer/audio/**/*",
      "scripts/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts"
      }
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
